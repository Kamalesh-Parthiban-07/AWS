Paste this code:

import boto3
import json
import os
import logging

logger = logging.getLogger()
logger.setLevel(logging.INFO)

asg_client = boto3.client('autoscaling', region_name='us-east-2')
sns_client = boto3.client('sns',         region_name='us-east-2')

ASG_NAME  = os.environ['ASG_NAME']
SNS_TOPIC = os.environ['SNS_TOPIC_ARN']

def send_email(subject, message):
    sns_client.publish(
        TopicArn = SNS_TOPIC,
        Subject  = subject,
        Message  = message
    )
    logger.info("Email sent via SNS ✅")

def lambda_handler(event, context):
    logger.info("Auto remediation triggered!")

    try:
        # Get current ASG details
        response = asg_client.describe_auto_scaling_groups(
            AutoScalingGroupNames=[ASG_NAME]
        )
        asg      = response['AutoScalingGroups'][0]
        current  = asg['DesiredCapacity']
        max_size = asg['MaxSize']

        logger.info(f"Current: {current} Max: {max_size}")

        if current < max_size:
            # Scale up by 2
            new_capacity = min(current + 2, max_size)

            asg_client.set_desired_capacity(
                AutoScalingGroupName = ASG_NAME,
                DesiredCapacity      = new_capacity,
                HonorCooldown        = False
            )

            logger.info(f"Scaled from {current} to {new_capacity}")

            send_email(
                subject = "Auto Remediation Triggered!",
                message = f"""
Auto Remediation Alert
──────────────────────
Reason  : EC2 CPU exceeded 90%
ASG     : {ASG_NAME}
Action  : Scaled from {current} to {new_capacity} instances
Status  : Done! No manual intervention needed ✅
──────────────────────
This was handled automatically.
                """
            )

        else:
            logger.info("Already at max capacity!")

            send_email(
                subject = "Auto Remediation - Manual Action Needed!",
                message = f"""
Auto Remediation Alert
──────────────────────
Reason  : EC2 CPU exceeded 90%
ASG     : {ASG_NAME}
Action  : Already at max capacity ({max_size})
Status  : Manual intervention needed! ❌
──────────────────────
Please investigate immediately.
                """
            )

        return {'statusCode': 200}

    except Exception as e:
        logger.error(f"Error: {str(e)}")

        send_email(
            subject = "Auto Remediation Failed!",
            message = f"""
Auto Remediation Alert
──────────────────────
Status : FAILED ❌
Error  : {str(e)}
ASG    : {ASG_NAME}
──────────────────────
Please investigate immediately.
            """
        )
        raise e

